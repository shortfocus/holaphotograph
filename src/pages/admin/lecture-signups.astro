---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="관리자 - 강의 신청 목록" headerOpaque hideFooter>
  <div class="mx-auto max-w-4xl px-4 pt-[calc(5.5rem+env(safe-area-inset-top,0px))] pb-8 sm:px-6 sm:pt-24 sm:pb-12">
    <h1 class="mb-6 text-2xl font-bold text-gray-900 sm:text-3xl">관리자</h1>
    <div class="mb-6 flex flex-col gap-4 sm:mb-8 sm:flex-row sm:items-center sm:justify-between">
      <h2 class="text-xl font-bold sm:text-2xl">강의 신청 목록</h2>
      <div class="flex flex-wrap items-center gap-3">
        <a
          href="/admin"
          class="inline-flex items-center gap-1 text-sm font-medium text-gray-600 hover:text-gray-900"
        >
          ← 고객 후기 관리로
        </a>
      </div>
    </div>

    <div id="sort-buttons" class="mb-3 hidden flex-wrap items-center justify-between gap-2">
      <button type="button" id="bulk-email-open-btn" class="cursor-pointer rounded-lg bg-[#E11D48] px-4 py-2 text-sm font-medium text-white shadow-md transition-colors hover:bg-[#be1640]">
        메일 일괄 발송
      </button>
      <div class="flex flex-wrap items-center gap-2">
      <span class="text-sm text-gray-500">정렬:</span>
      <button type="button" id="sort-btn-email" data-sort="email" data-arrow="▲" class="sort-btn cursor-pointer whitespace-nowrap rounded border border-gray-300 bg-white px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50">
        이메일
      </button>
      <button type="button" id="sort-btn-created-at" data-sort="created_at" data-arrow="▼" class="sort-btn cursor-pointer whitespace-nowrap rounded border border-gray-300 bg-white px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50">
        신청일시
      </button>
      </div>
    </div>

    <div id="signups-container" class="w-full overflow-x-auto overflow-y-hidden rounded-lg border border-gray-200 bg-white shadow">
      <p id="signups-loading" class="p-6 text-gray-500">로딩 중...</p>
      <div id="signups-empty" class="hidden p-6 text-center text-gray-500">
        아직 강의 신청 이메일이 없습니다.
      </div>
      <table id="signups-table" class="hidden divide-y divide-gray-200" style="min-width: max-content; width: 100%;">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="w-10 px-2 py-3 text-left sm:px-4"><span class="sr-only">선택</span><input type="checkbox" id="signup-select-all" class="rounded border-gray-300" aria-label="전체 선택" /></th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 sm:px-6">번호</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 sm:px-6">이메일</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 sm:px-6">신청일시</th>
          </tr>
        </thead>
        <tbody id="signups-tbody" class="divide-y divide-gray-200 bg-white">
        </tbody>
      </table>
    </div>

    <!-- 메일 일괄 발송 모달 -->
    <div id="bulk-email-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4" aria-modal="true" role="dialog">
      <div class="max-h-[90vh] w-full max-w-lg overflow-y-auto rounded-xl bg-white shadow-xl">
        <div class="sticky top-0 flex items-center justify-between border-b border-gray-200 bg-white px-4 py-3">
          <h3 class="text-lg font-semibold text-gray-900">메일 일괄 발송</h3>
          <button type="button" id="bulk-email-close-btn" class="cursor-pointer rounded p-1 text-gray-400 hover:bg-gray-100 hover:text-gray-600" aria-label="닫기">&times;</button>
        </div>
        <form id="bulk-email-form" class="space-y-4 p-4">
          <p id="bulk-email-target" class="text-sm text-gray-600">발송 대상: 전체 0명</p>
          <div>
            <label for="bulk-email-subject" class="mb-1 block text-sm font-medium text-gray-700">제목</label>
            <input type="text" id="bulk-email-subject" name="subject" required class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" placeholder="이메일 제목" />
          </div>
          <div>
            <label for="bulk-email-body" class="mb-1 block text-sm font-medium text-gray-700">본문</label>
            <textarea id="bulk-email-body" name="body" required rows="10" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" placeholder="본문 내용 (개행은 그대로 반영됩니다)"></textarea>
          </div>
          <div id="bulk-email-status" class="hidden text-sm"></div>
          <div class="flex justify-end gap-2">
            <button type="button" id="bulk-email-cancel-btn" class="cursor-pointer rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">취소</button>
            <button type="submit" id="bulk-email-submit-btn" class="cursor-pointer rounded-lg bg-[#0F172A] px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">발송</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<style>
  .sort-btn[data-arrow]::after {
    content: " " attr(data-arrow);
  }
  #signups-container {
    -webkit-overflow-scrolling: touch;
  }
</style>

<script>
  import { fetchLectureSignups, sendLectureSignupsEmail, type LectureSignup } from "../../lib/api";

  let loadingEl: HTMLElement;
  let emptyEl: HTMLElement;
  let tableEl: HTMLElement;
  let tbodyEl: HTMLElement;
  let sortButtonsEl: HTMLElement;

  function escapeHtml(s: string) {
    const div = document.createElement("div");
    div.textContent = s;
    return div.innerHTML;
  }

  let allSignups: LectureSignup[] = [];
  let sortBy: "email" | "created_at" = "created_at";
  let sortDir: "asc" | "desc" = "desc";

  function sortSignups(signups: LectureSignup[], by: typeof sortBy, dir: typeof sortDir): LectureSignup[] {
    return [...signups].sort((a, b) => {
      let cmp = 0;
      if (by === "email") {
        cmp = a.email.localeCompare(b.email, "ko");
      } else {
        cmp = new Date(a.created_at).getTime() - new Date(b.created_at).getTime();
      }
      return dir === "asc" ? cmp : -cmp;
    });
  }

  function renderTable() {
    const sorted = sortSignups(allSignups, sortBy, sortDir);
    tbodyEl.innerHTML = sorted
      .map(
        (s: LectureSignup, i: number) => `
        <tr>
          <td class="w-10 px-2 py-3 sm:px-4"><input type="checkbox" class="signup-checkbox rounded border-gray-300" data-id="${s.id}" aria-label="선택" /></td>
          <td class="whitespace-nowrap px-4 py-3 text-sm text-gray-500 sm:px-6">${i + 1}</td>
          <td class="px-4 py-3 text-sm text-gray-900 sm:px-6"><a href="mailto:${escapeHtml(s.email)}" class="text-blue-600 hover:underline">${escapeHtml(s.email)}</a></td>
          <td class="whitespace-nowrap px-4 py-3 text-sm text-gray-500 sm:px-6">${new Date(s.created_at).toLocaleString("ko-KR")}</td>
        </tr>
      `
      )
      .join("");

    // 화살표는 data-arrow 속성 + CSS ::after로 표시 (JS textContent 덮어쓰기 회피)
    const ARROW_UP = "\u25B2";
    const ARROW_DOWN = "\u25BC";
    const defaultDir: Record<"email" | "created_at", "asc" | "desc"> = { email: "asc", created_at: "desc" };

    const btnEmail = document.getElementById("sort-btn-email");
    const btnCreatedAt = document.getElementById("sort-btn-created-at");
    if (btnEmail) {
      const active = sortBy === "email";
      const dir = active ? sortDir : defaultDir.email;
      btnEmail.textContent = "이메일";
      btnEmail.setAttribute("data-arrow", dir === "asc" ? ARROW_UP : ARROW_DOWN);
      btnEmail.classList.toggle("border-blue-500", active);
      btnEmail.classList.toggle("bg-blue-50", active);
      btnEmail.classList.toggle("text-blue-700", active);
      btnEmail.classList.toggle("border-gray-300", !active);
      btnEmail.classList.toggle("bg-white", !active);
      btnEmail.classList.toggle("text-gray-700", !active);
    }
    if (btnCreatedAt) {
      const active = sortBy === "created_at";
      const dir = active ? sortDir : defaultDir.created_at;
      btnCreatedAt.textContent = "신청일시";
      btnCreatedAt.setAttribute("data-arrow", dir === "asc" ? ARROW_UP : ARROW_DOWN);
      btnCreatedAt.classList.toggle("border-blue-500", active);
      btnCreatedAt.classList.toggle("bg-blue-50", active);
      btnCreatedAt.classList.toggle("text-blue-700", active);
      btnCreatedAt.classList.toggle("border-gray-300", !active);
      btnCreatedAt.classList.toggle("bg-white", !active);
      btnCreatedAt.classList.toggle("text-gray-700", !active);
    }
  }

  async function load() {
    try {
      const signups = await fetchLectureSignups();
      loadingEl.classList.add("hidden");

      if (signups.length === 0) {
        emptyEl.classList.remove("hidden");
        return;
      }

      allSignups = signups;
      emptyEl.classList.add("hidden");
      tableEl.classList.remove("hidden");
      sortButtonsEl.classList.remove("hidden");
      sortButtonsEl.classList.add("flex");
      renderTable();
      bindBulkEmail();
    } catch (e) {
      loadingEl.textContent = "목록을 불러올 수 없습니다: " + (e as Error).message;
      loadingEl.classList.remove("text-gray-500");
      loadingEl.classList.add("text-red-600");
    }
  }

  function bindBulkEmail() {
    const modal = document.getElementById("bulk-email-modal");
    const openBtn = document.getElementById("bulk-email-open-btn");
    const closeBtn = document.getElementById("bulk-email-close-btn");
    const cancelBtn = document.getElementById("bulk-email-cancel-btn");
    const form = document.getElementById("bulk-email-form") as HTMLFormElement;
    const targetEl = document.getElementById("bulk-email-target");
    const statusEl = document.getElementById("bulk-email-status");
    const submitBtn = document.getElementById("bulk-email-submit-btn");
    const selectAll = document.getElementById("signup-select-all") as HTMLInputElement;
    const subjectInput = document.getElementById("bulk-email-subject") as HTMLInputElement | null;
    const bodyTextarea = document.getElementById("bulk-email-body") as HTMLTextAreaElement | null;

    function getSelectedIds(): number[] {
      return Array.from(document.querySelectorAll<HTMLInputElement>(".signup-checkbox:checked")).map((cb) => parseInt(cb.dataset.id!, 10));
    }

    function updateTargetText() {
      if (!targetEl) return;
      const selected = getSelectedIds();
      if (selected.length === 0) {
        targetEl.textContent = `발송 대상: 전체 ${allSignups.length}명`;
      } else {
        targetEl.textContent = `발송 대상: 선택 ${selected.length}명`;
      }
    }

    function openModal() {
      if (!modal) return;
      updateTargetText();
      if (subjectInput) subjectInput.value = "";
      if (bodyTextarea) bodyTextarea.value = "";
      statusEl?.classList.add("hidden");
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    }

    function closeModal() {
      modal?.classList.add("hidden");
      modal?.classList.remove("flex");
    }

    openBtn?.addEventListener("click", openModal);
    closeBtn?.addEventListener("click", closeModal);
    cancelBtn?.addEventListener("click", closeModal);
    modal?.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });

    selectAll?.addEventListener("change", () => {
      tbodyEl.querySelectorAll<HTMLInputElement>(".signup-checkbox").forEach((cb) => {
        cb.checked = selectAll.checked;
      });
      if (modal?.classList.contains("flex")) updateTargetText();
    });
    tbodyEl.addEventListener("change", () => {
      if (modal?.classList.contains("flex")) updateTargetText();
    });

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!subjectInput || !bodyTextarea) return;
      const subject = subjectInput.value.trim();
      const body = bodyTextarea.value.trim();
      if (!subject || !body) return;
      const selected = getSelectedIds();
      const recipientIds = selected.length > 0 ? selected : undefined;
      if (!statusEl) return;
      statusEl.classList.remove("hidden");
      statusEl.textContent = "발송 중...";
      statusEl.className = "text-sm text-gray-600";
      submitBtn?.setAttribute("disabled", "disabled");
      try {
        const result = await sendLectureSignupsEmail(subject, body, recipientIds);
        statusEl.textContent = `발송 완료: ${result.sent}명 성공${result.failed > 0 ? `, ${result.failed}명 실패` : ""}.`;
        statusEl.className = "text-sm " + (result.failed > 0 ? "text-amber-600" : "text-green-600");
        if (result.errors && result.errors.length > 0) {
          statusEl.textContent += " " + result.errors.slice(0, 3).join("; ");
        }
      } catch (err) {
        statusEl.textContent = "발송 실패: " + (err as Error).message;
        statusEl.className = "text-sm text-red-600";
      } finally {
        submitBtn?.removeAttribute("disabled");
      }
    });
  }

  function init() {
    loadingEl = document.getElementById("signups-loading")!;
    emptyEl = document.getElementById("signups-empty")!;
    tableEl = document.getElementById("signups-table")!;
    tbodyEl = document.getElementById("signups-tbody")!;
    sortButtonsEl = document.getElementById("sort-buttons")!;

    sortButtonsEl.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest(".sort-btn");
      if (!btn || allSignups.length === 0) return;
      const key = ((btn as HTMLButtonElement).getAttribute("data-sort") || "") as "email" | "created_at";
      if (sortBy === key) {
        sortDir = sortDir === "asc" ? "desc" : "asc";
      } else {
        sortBy = key;
        sortDir = key === "created_at" ? "desc" : "asc";
      }
      renderTable();
    });

    load();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
