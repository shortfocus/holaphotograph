---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- 강의 홍보 팝업 (메인 진입 시 1회) -->
  <div
    id="class-promo-popup"
    class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/60 p-3 backdrop-blur-sm"
    role="dialog"
    aria-modal="true"
    aria-labelledby="class-promo-title"
  >
    <div class="relative mt-8 flex max-h-[85vh] w-full max-w-sm flex-col overflow-hidden rounded-xl bg-[#0F172A] shadow-2xl ring-1 ring-white/10 sm:mt-12">
      <!-- 헤더 -->
      <div class="relative flex shrink-0 items-center justify-center border-b border-slate-700/50 bg-[#0F172A] p-4">
        <h2 id="class-promo-title" class="text-lg font-bold text-white sm:text-xl">올라포토 강의 안내</h2>
        <button
          type="button"
          id="class-promo-close"
          class="absolute right-4 top-1/2 -translate-y-1/2 cursor-pointer rounded p-1.5 text-slate-400 hover:bg-white/10 hover:text-white"
          aria-label="팝업 닫기"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <!-- 슬라이드 영역: 모바일에서 이미지 잘림 방지(트랙/슬라이드 너비 명시, min-w-0) -->
      <div id="class-promo-slider" class="relative flex min-h-0 min-w-0 flex-1 flex-col overflow-hidden">
        <div class="relative min-h-0 min-w-0 flex-1 overflow-hidden">
          <div class="class-promo-track flex h-full transition-transform duration-300 ease-out" style="width: 200%; transform: translateX(0);">
            <div class="class-promo-slide flex min-h-0 w-1/2 shrink-0 flex-col px-2 py-4">
              <div class="flex min-h-0 min-w-0 flex-1 items-center justify-center overflow-hidden">
                <a href="/notice?id=2" class="class-promo-image-link flex min-w-0 max-w-full cursor-pointer" aria-label="후지필름 카메라 클래스 공지 상세로 이동">
                  <img src="/images/class-exposure.png" alt="노출3요소 class · 2026.03.14(토) 오후 1시~3시 · 즐카 · 2만원" class="max-h-[60vh] w-full max-w-full rounded-lg object-contain object-center" />
                </a>
              </div>
            </div>
            <div class="class-promo-slide flex min-h-0 w-1/2 shrink-0 flex-col px-2 py-4">
              <div class="flex min-h-0 min-w-0 flex-1 items-center justify-center overflow-hidden">
                <a href="/notice?id=2" class="class-promo-image-link flex min-w-0 max-w-full cursor-pointer" aria-label="후지필름 카메라 클래스 공지 상세로 이동">
                  <img src="/images/class-xe5.png" alt="X-E5 class · 2026.03.14(토) 오전 10시~12시 · 즐카 · 2만원" class="max-h-[60vh] w-full max-w-full rounded-lg object-contain object-center" />
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- 푸터 -->
      <div class="flex shrink-0 flex-col gap-2 border-t border-slate-700/50 p-4 sm:flex-row sm:items-center sm:justify-between">
        <label class="flex cursor-pointer items-center gap-1.5 text-xs text-slate-400">
          <input type="checkbox" id="class-promo-dont-show" class="rounded border-slate-600 bg-slate-800 text-[#E11D48] focus:ring-[#E11D48]" />
          오늘 하루 안 보기
        </label>
        <button type="button" id="class-promo-close-btn" class="cursor-pointer rounded-lg bg-[#E11D48] px-4 py-2 text-xs font-semibold text-white hover:bg-[#be123c]">
          닫기
        </button>
      </div>
    </div>
  </div>

  <!-- 2. 히어로 섹션 (캐러셀) - 플로팅 바 높이 제외한 뷰포트 -->
  <section
    class="hero-section relative left-0 right-0 w-full min-w-full overflow-hidden bg-[#0F172A] pt-[4rem]"
  >
    <div
      class="hero-glow absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(225,29,72,0.1),transparent)] pointer-events-none"
      aria-hidden="true"
    >
    </div>
    <div
      class="hero-noise absolute inset-0 pointer-events-none"
      aria-hidden="true"
    >
    </div>

    <div
      id="hero-carousel"
      class="relative flex h-full flex-col overflow-hidden"
    >
      <div
        class="hero-carousel-track flex h-full flex-1 items-center transition-transform duration-500 ease-out"
        style="transform: translateX(0);"
      >
        <!-- Slide 1: Camera Review Archive -->
        <div
          class="hero-slide flex h-full min-h-0 shrink-0 items-center justify-center overflow-y-auto overflow-x-hidden py-2 sm:py-4 lg:py-6"
        >
          <div
            class="relative mx-auto flex w-full min-w-0 max-w-7xl flex-col items-center justify-center gap-8 px-4 py-24 sm:px-6 lg:flex-row lg:gap-16 lg:px-8"
          >
            <div class="flex-1 text-center lg:text-left">
              <span
                class="hero-animate inline-block rounded-full border border-[#E11D48]/40 bg-[#E11D48]/10 px-4 py-1.5 text-xs font-medium uppercase tracking-wider text-red-300"
                style="animation-delay: 0ms; opacity: 0"
                >Camera Review Archive</span
              >
              <h1
                class="hero-animate mt-6 text-3xl font-bold leading-tight tracking-tight text-white sm:text-4xl md:text-5xl lg:text-6xl"
                style="animation-delay: 100ms; opacity: 0"
              >
                카메라 선택부터 <span class="whitespace-nowrap"
                  >촬영 노하우까지</span
                ><br />
                <span class="text-[#F43F5E] whitespace-nowrap"
                  >실전 기반 리뷰 플랫폼</span
                >
              </h1>
              <p
                class="hero-animate mx-auto mt-4 max-w-xl text-base leading-relaxed text-slate-400 sm:text-lg lg:mx-0 lg:text-xl"
                style="animation-delay: 200ms; opacity: 0"
              >
                <span class="whitespace-nowrap">장비 비교</span> · <span
                  class="whitespace-nowrap">실사용 테스트</span
                > · <span class="whitespace-nowrap">구매 가이드</span>
              </p>
              <div
                class="hero-animate mt-8 flex items-center justify-center gap-6 lg:justify-start"
                style="animation-delay: 300ms; opacity: 0"
              >
                <a
                  href="https://youtube.com/channel/UCsD5VP6TvRMt-sq0q25HlIA"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hero-channel-icon group"
                  aria-label="유튜브"
                >
                  <img src="/icons/youtube.svg" alt="" aria-hidden="true" />
                </a>
                <a
                  href="https://blog.naver.com/holaphotograph"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hero-channel-icon"
                  aria-label="네이버 블로그"
                >
                  <img src="/icons/naver-blog-hover.svg" alt="" aria-hidden="true" />
                </a>
                <a
                  href="https://www.instagram.com/snap.hola"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hero-channel-icon group"
                  aria-label="인스타그램"
                >
                  <img src="/icons/instagram.svg" alt="" aria-hidden="true" />
                </a>
                <a
                  href="mailto:holaphotographer@gmail.com"
                  class="hero-channel-icon group"
                  aria-label="문의하기"
                >
                  <img src="/icons/contact.svg" alt="" aria-hidden="true" />
                </a>
              </div>
            </div>
            <div
              class="hero-animate flex-1 min-w-0"
              style="animation-delay: 150ms; opacity: 0"
            >
              <div
                class="overflow-hidden rounded-2xl shadow-2xl shadow-black/30 ring-1 ring-white/10"
              >
                <iframe
                  src="https://www.youtube.com/embed/jMMTLjQLTWg?rel=0&autoplay=1&mute=1"
                  title="올라포토 유튜브 영상"
                  class="aspect-video w-full min-h-[200px] sm:min-h-[280px]"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen></iframe>
              </div>
            </div>
          </div>
        </div>
        <!-- Slide 2: 강의 안내 (팝업과 동일 콘텐츠) -->
        <div
          class="hero-slide flex h-full min-h-0 shrink-0 items-center justify-center overflow-y-auto overflow-x-hidden py-4 sm:py-4 lg:py-6"
        >
          <div class="hero-slide-2-inner mx-auto flex w-full min-w-0 max-w-2xl flex-col items-center justify-center px-4 text-center sm:px-4">
            <span
              class="inline-block rounded-full border border-[#F43F5E]/40 bg-[#F43F5E]/10 px-3 py-1 text-xs font-medium text-red-300 backdrop-blur sm:px-4 sm:py-1.5 sm:text-sm"
              >강의 안내</span
            >
            <h1
              class="mt-3 text-2xl font-bold tracking-tight text-white sm:mt-6 sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl"
            >
              <span class="text-[#F43F5E]">올라포토</span> 강의 안내
            </h1>
            <p class="hero-slide-2-desc mx-auto mt-2 min-w-0 max-w-lg text-sm leading-loose text-slate-400 sm:mt-4 sm:text-lg sm:leading-loose lg:text-xl lg:leading-loose">
              X-E5 매뉴얼 · 노출 3요소 강의를<br class="sm:hidden" /> 오프라인에서 만나보세요
            </p>
            <!-- 모바일 전용: 강의 이미지 1장 (class-exposure) -->
            <div class="hero-slide-2-mobile-images mx-auto mt-5 w-full max-w-[320px] sm:mt-0 sm:hidden">
              <a
                href="/notice?id=2"
                class="hero-slide-2-mobile-single inline-flex overflow-hidden rounded-xl ring-1 ring-white/10 transition-transform hover:scale-[1.02]"
                aria-label="노출3요소 class 공지 상세"
              >
                <img
                  src="/images/class-exposure.png"
                  alt="노출3요소 class · 2026.03.14(토) 오후 1시~3시 · 즐카 · 2만원"
                  class="max-h-[40vh] block rounded-xl object-contain object-center"
                />
              </a>
            </div>
            <!-- 데스크톱: 강의 이미지 2장 나란히 -->
            <div
              class="hero-class-images mx-auto mt-5 hidden w-full max-w-lg sm:mt-6 sm:flex sm:flex-row sm:justify-center sm:gap-4 sm:overflow-visible"
              style="-webkit-overflow-scrolling: touch; scrollbar-width: none;"
            >
              <a
                href="/notice?id=2"
                class="hero-class-slide flex flex-shrink-0 snap-center justify-center overflow-hidden rounded-xl ring-1 ring-white/10 transition-transform hover:scale-[1.02] sm:w-1/2 sm:min-w-0 sm:flex-1 sm:snap-align-none"
                aria-label="노출3요소 class 공지 상세"
              >
                <img
                  src="/images/class-exposure.png"
                  alt="노출3요소 class · 2026.03.14(토) 오후 1시~3시 · 즐카 · 2만원"
                  class="max-h-[36vh] w-full max-w-[260px] object-contain object-center sm:max-h-[45vh]"
                />
              </a>
              <a
                href="/notice?id=2"
                class="hero-class-slide flex flex-shrink-0 snap-center justify-center overflow-hidden rounded-xl ring-1 ring-white/10 transition-transform hover:scale-[1.02] sm:w-1/2 sm:min-w-0 sm:flex-1 sm:snap-align-none"
                aria-label="X-E5 class 공지 상세"
              >
                <img
                  src="/images/class-xe5.png"
                  alt="X-E5 class · 2026.03.14(토) 오전 10시~12시 · 즐카 · 2만원"
                  class="max-h-[36vh] w-full max-w-[260px] object-contain object-center sm:max-h-[45vh]"
                />
              </a>
            </div>
            <a
              href="/notice?id=2"
              class="hero-cta mt-5 inline-flex items-center gap-2 rounded-2xl bg-[#E11D48] px-6 py-3 text-base font-semibold text-white shadow-lg transition-transform duration-200 hover:scale-105 hover:bg-[#be123c] active:scale-100 sm:mt-6 sm:px-8 sm:py-3.5 sm:text-lg"
            >
              자세히 보기
            </a>
          </div>
        </div>
        <!-- Slide 3: 고객 리뷰 -->
        <div
          class="hero-slide flex h-full min-h-0 shrink-0 items-center justify-center overflow-y-auto overflow-x-hidden py-4 sm:py-4 lg:py-6"
        >
          <div class="mx-auto flex w-full max-w-2xl flex-col items-center justify-center px-4 text-center sm:px-4">
            <span
              class="inline-block rounded-full border border-[#F43F5E]/40 bg-[#F43F5E]/10 px-3 py-1 text-xs font-medium text-red-300 backdrop-blur sm:px-4 sm:py-1.5 sm:text-sm"
              >실제 이용 후기</span
            >
            <h1
              class="mt-3 text-2xl font-bold tracking-tight text-white sm:mt-6 sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl"
            >
              <span class="text-[#F43F5E]">고객 리뷰</span> 확인하기
            </h1>
            <p
              class="mx-auto mt-2 max-w-lg text-sm leading-loose text-slate-400 sm:mt-4 sm:text-lg sm:leading-loose lg:text-xl lg:leading-loose"
            >
              올라포토와 함께한 고객님들의 솔직한 후기를 확인해보세요.<br />
              카메라 리뷰 · 촬영 서비스 만족도
            </p>
            <a
              href="/reviews"
              class="hero-cta mt-4 inline-flex items-center gap-2 rounded-2xl border-2 border-[#E11D48] bg-transparent px-6 py-3 text-base font-semibold text-white shadow-md transition-transform duration-200 hover:scale-105 hover:bg-[#E11D48]/20 active:scale-100 sm:mt-6 sm:px-8 sm:py-3.5 sm:text-lg"
            >
              <svg
                class="h-5 w-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                ></path></svg
              >
              리뷰 보러 가기
            </a>
          </div>
        </div>
      </div>

      <!-- 인디케이터 -->
      <div
        class="absolute bottom-5 left-1/2 z-10 flex -translate-x-1/2 items-center gap-2.5 rounded-full border border-slate-600/40 bg-slate-800/80 px-4 py-2 shadow-lg backdrop-blur-sm"
      >
        <button
          type="button"
          data-hero-dot="0"
          class="hero-dot cursor-pointer h-2.5 w-7 rounded-full bg-[#E11D48] shadow-sm transition-all"
          aria-label="슬라이드 1"
          aria-current="page"></button>
        <button
          type="button"
          data-hero-dot="1"
          class="hero-dot cursor-pointer h-2.5 w-2.5 rounded-full bg-slate-500 transition-all hover:bg-slate-400"
          aria-label="슬라이드 2"></button>
        <button
          type="button"
          data-hero-dot="2"
          class="hero-dot cursor-pointer h-2.5 w-2.5 rounded-full bg-slate-500 transition-all hover:bg-slate-400"
          aria-label="슬라이드 3"></button>
      </div>
    </div>
  </section>

  <!-- 3. 실전 영상 리뷰 섹션 -->
  <section
    id="youtube-long"
    class="section-spacing border-t border-slate-200/60 bg-white py-14 sm:py-16"
  >
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="section-title mb-3">
        <span class="block text-sm font-medium text-[#6B7280] sm:text-base"
          >후지필름 카메라 클래스 누적 수강생 1위</span
        >
        <span class="mt-1 block text-2xl font-bold text-[#111827] sm:text-3xl"
          >📺 올라포토 카메라 매뉴얼 클래스</span
        >
      </h2>
      <div
        id="youtube-long-grid"
        class="scroll-row flex w-full min-w-0 gap-8 pb-2 pl-4 sm:pl-6 pr-4 sm:pr-6"
      >
        <div
          class="animate-pulse shrink-0 w-[280px] sm:w-[340px] rounded-lg overflow-hidden bg-gray-200 aspect-video"
        >
        </div>
        <div
          class="animate-pulse shrink-0 w-[280px] sm:w-[340px] rounded-lg overflow-hidden bg-gray-200 aspect-video"
        >
        </div>
        <div
          class="animate-pulse shrink-0 w-[280px] sm:w-[340px] rounded-lg overflow-hidden bg-gray-200 aspect-video"
        >
        </div>
      </div>
    </div>
  </section>

  <!-- 5. 고품격! 올라포토 카메라/렌즈 리뷰 (블로그) -->
  <section
    id="blog"
    class="section-spacing border-t border-slate-200/60 bg-white py-14 sm:py-16"
  >
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="section-title mb-3">
        <span class="block text-sm font-medium text-[#6B7280] sm:text-base"
          >실전 촬영 기반 전문가 리뷰</span
        >
        <span class="mt-1 block text-2xl font-bold text-[#111827] sm:text-3xl"
          >✍ 고품격! 올라포토 카메라/렌즈 리뷰</span
        >
      </h2>
      <div
        id="blog-grid"
        class="scroll-row flex w-full min-w-0 gap-8 pb-2 pl-4 sm:pl-6 pr-4 sm:pr-6"
      >
        <div
          class="animate-pulse shrink-0 w-[209px] rounded-lg overflow-hidden bg-gray-200 aspect-[209/314]"
        >
        </div>
        <div
          class="animate-pulse shrink-0 w-[209px] rounded-lg overflow-hidden bg-gray-200 aspect-[209/314]"
        >
        </div>
        <div
          class="animate-pulse shrink-0 w-[209px] rounded-lg overflow-hidden bg-gray-200 aspect-[209/314]"
        >
        </div>
      </div>
    </div>
  </section>

  <!-- 6. 빠르게 보는 장비 팁 (Shorts) -->
  <section
    id="youtube-shorts"
    class="section-spacing border-t border-slate-200/60 bg-white py-14 sm:py-16"
  >
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="section-title mb-3">
        <span class="block text-sm font-medium text-[#6B7280] sm:text-base"
          >Shorts로 보는 핵심 포인트</span
        >
        <span class="mt-1 block text-2xl font-bold text-[#111827] sm:text-3xl"
          >🎬 빠르게 보는 장비 팁</span
        >
      </h2>
      <div
        id="youtube-shorts-grid"
        class="scroll-row flex w-full min-w-0 gap-8 pb-2 pl-4 sm:pl-6 pr-4 sm:pr-6"
      >
        <div
          class="animate-pulse shrink-0 w-[209px] rounded-lg overflow-hidden bg-gray-200 aspect-[209/314]"
        >
        </div>
        <div
          class="animate-pulse shrink-0 w-[209px] rounded-lg overflow-hidden bg-gray-200 aspect-[209/314]"
        >
        </div>
        <div
          class="animate-pulse shrink-0 w-[209px] rounded-lg overflow-hidden bg-gray-200 aspect-[209/314]"
        >
        </div>
      </div>
    </div>
  </section>

  <!-- 7. 성과 지표 (Performance Section) -->
  <section
    class="section-spacing border-t border-slate-200/60 bg-[#F8FAFC] py-14 sm:py-16"
  >
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p
        class="section-title mb-8 text-center text-sm font-semibold uppercase tracking-wider text-[#6B7280]"
      >
        누적 성과
      </p>
      <div class="grid gap-8 sm:grid-cols-3">
        <div class="text-center">
          <p
            id="stats-youtube-subscribers"
            class="count-up text-5xl font-bold text-[#E11D48] sm:text-6xl"
          >
            0
          </p>
          <p class="mt-2 text-[#6B7280]">유튜브 구독자</p>
        </div>
        <div class="text-center">
          <p
            id="stats-youtube-views"
            class="count-up text-5xl font-bold text-[#E11D48] sm:text-6xl"
          >
            0
          </p>
          <p class="mt-2 text-[#6B7280]">월간 조회수</p>
        </div>
        <div class="text-center">
          <p
            id="stats-naver-visitors"
            class="count-up text-5xl font-bold text-[#E11D48] sm:text-6xl"
          >
            0
          </p>
          <p class="mt-2 text-[#6B7280]">누적 방문자</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. 협업 / 광고 문의 -->
  <section
    id="about"
    class="section-spacing border-t border-slate-200/60 !mt-0 bg-white py-14 sm:py-16"
  >
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2
        class="section-title mb-3 text-2xl font-bold text-[#111827] sm:text-3xl"
      >
        협업 및 광고 문의
      </h2>
      <p class="mb-12 text-[#6B7280]">브랜드 협업·광고 문의를 환영합니다</p>
      <div
        class="flex flex-col items-stretch gap-4 sm:flex-row sm:justify-center sm:gap-6"
      >
        <a
          href="https://youtube.com/channel/UCsD5VP6TvRMt-sq0q25HlIA"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-1 flex-col items-center gap-2 rounded-xl border border-slate-200 bg-slate-50/50 px-6 py-5 transition-all hover:border-[#E11D48] hover:bg-[#E11D48]/5 sm:max-w-[280px]"
          aria-label="유튜브"
        >
          <img
            src="/icons/youtube.svg"
            alt=""
            class="h-6 w-6 shrink-0"
            aria-hidden="true"
          />
          <span
            class="text-sm font-semibold text-[#111827] group-hover:text-[#E11D48]"
            >유튜브</span
          >
        </a>
        <a
          href="https://blog.naver.com/holaphotograph"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-1 flex-col items-center gap-2 rounded-xl border border-slate-200 bg-slate-50/50 px-6 py-5 transition-all hover:border-[#E11D48] hover:bg-[#E11D48]/5 sm:max-w-[280px]"
          aria-label="네이버 블로그"
        >
          <img
            src="/icons/naver-blog-hover.svg"
            alt=""
            class="h-6 w-6 shrink-0"
            aria-hidden="true"
          />
          <span
            class="text-sm font-semibold text-[#111827] group-hover:text-[#E11D48]"
            >네이버 블로그</span
          >
        </a>
        <a
          href="https://www.instagram.com/snap.hola"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-1 flex-col items-center gap-2 rounded-xl border border-slate-200 bg-slate-50/50 px-6 py-5 transition-all hover:border-[#E11D48] hover:bg-[#E11D48]/5 sm:max-w-[280px]"
          aria-label="인스타그램"
        >
          <img
            src="/icons/instagram.svg"
            alt=""
            class="h-6 w-6 shrink-0"
            aria-hidden="true"
          />
          <span
            class="text-sm font-semibold text-[#111827] group-hover:text-[#E11D48]"
            >인스타그램</span
          >
        </a>
        <a
          href="mailto:holaphotographer@gmail.com"
          class="group flex flex-1 flex-col items-center gap-2 rounded-xl border border-slate-200 bg-slate-50/50 px-6 py-5 transition-all hover:border-[#E11D48] hover:bg-[#E11D48]/5 sm:max-w-[280px]"
        >
          <img
            src="/icons/contact.svg"
            alt=""
            class="h-6 w-6 shrink-0 opacity-70"
            aria-hidden="true"
          />
          <span
            class="text-sm font-semibold text-[#111827] group-hover:text-[#E11D48]"
            >이메일</span
          >
          <span
            class="text-xs text-[#6B7280] break-all group-hover:text-[#E11D48]/90"
            >holaphotographer@gmail.com</span
          >
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  import {
    fetchYoutubeLatest,
    fetchChannelStats,
    getRssThumbnailUrl,
    type NaverRssItem,
    type YoutubeVideoItem,
  } from "../lib/api";
  import { FEATURED_BLOG } from "../data/featured-blog";

  // Hero Carousel
  (function initHeroCarousel() {
    const track = document.querySelector(".hero-carousel-track") as HTMLElement;
    const dots = document.querySelectorAll("[data-hero-dot]");
    const total = 3;
    let current = 0;
    let autoplayTimer: ReturnType<typeof setInterval> | null = null;
    const AUTOPLAY_MS = 5000;

    function goTo(i: number) {
      current = ((i % total) + total) % total;
      if (track) track.style.transform = `translateX(-${current * (100 / 3)}%)`;
      dots.forEach((d, idx) => {
        if (idx === current) {
          d.setAttribute("aria-current", "page");
          d.classList.add("bg-[#E11D48]", "w-7");
          d.classList.remove("bg-slate-500", "w-2.5");
        } else {
          d.removeAttribute("aria-current");
          d.classList.add("bg-slate-500", "w-2.5");
          d.classList.remove("bg-[#E11D48]", "w-7");
        }
      });
    }

    function next() {
      goTo(current + 1);
    }
    function prev() {
      goTo(current - 1);
    }

    function startAutoplay() {
      stopAutoplay();
      autoplayTimer = setInterval(next, AUTOPLAY_MS);
    }
    function stopAutoplay() {
      if (autoplayTimer) clearInterval(autoplayTimer);
      autoplayTimer = null;
    }

    dots.forEach((d, i) =>
      d.addEventListener("click", () => {
        goTo(i);
        startAutoplay();
      }),
    );
    const carousel = track?.closest("#hero-carousel");
    carousel?.addEventListener("mouseenter", stopAutoplay);
    carousel?.addEventListener("mouseleave", startAutoplay);

    let touchStartX = 0;
    carousel?.addEventListener(
      "touchstart",
      (e) => {
        touchStartX = (e as TouchEvent).touches[0].clientX;
      },
      { passive: true },
    );
    carousel?.addEventListener(
      "touchend",
      (e) => {
        const te = e as TouchEvent;
        const dx = te.changedTouches[0].clientX - touchStartX;
        if (Math.abs(dx) > 50) {
          dx < 0 ? next() : prev();
          startAutoplay();
        }
      },
      { passive: true },
    );

    startAutoplay();
  })();

  const youtubeLongGrid = document.getElementById("youtube-long-grid")!;
  const youtubeShortsGrid = document.getElementById("youtube-shorts-grid")!;
  const blogGrid = document.getElementById("blog-grid")!;
  const LIMIT = 6;

  /** 첫 번째 섹션(롱폼 영상) 노출 순서 (video ID) */
  const YOUTUBE_LONG_ORDER = [
    "jMMTLjQLTWg",
    "c-xvb8f9OHM",
    "qEP4MaioFPM",
    "cXfv3-85u6M",
    "p8K7iu1Rzpo",
  ];
  function getVideoId(link: string): string | null {
    if (!link || typeof link !== "string") return null;
    const trimmed = link.trim();
    if (/^[a-zA-Z0-9_-]{11}$/.test(trimmed)) return trimmed;
    const m = trimmed.match(/(?:youtu\.be\/|[/?&]v=)([a-zA-Z0-9_-]{11})/);
    return m ? m[1] : null;
  }
  function sortByPreferredOrder<T extends { link: string }>(
    items: T[],
    order: string[],
  ): T[] {
    const orderMap = new Map(order.map((id, i) => [id, i]));
    return [...items].sort((a, b) => {
      const idA = getVideoId(a.link);
      const idB = getVideoId(b.link);
      const ia = orderMap.get(idA ?? "") ?? order.length;
      const ib = orderMap.get(idB ?? "") ?? order.length;
      if (ia !== ib) return ia - ib;
      return 0;
    });
  }

  function formatCount(n: string | number): string {
    const num = typeof n === "string" ? parseInt(n, 10) : n;
    if (isNaN(num)) return "—";
    if (num >= 100000000)
      return (num / 100000000).toFixed(1).replace(/\.0$/, "") + "억";
    if (num >= 10000)
      return (num / 10000).toFixed(1).replace(/\.0$/, "") + "만";
    return num.toLocaleString();
  }

  function escapeHtml(s: string) {
    const div = document.createElement("div");
    div.textContent = s;
    return div.innerHTML;
  }

  function stripHtml(html: string): string {
    const div = document.createElement("div");
    div.innerHTML = html;
    return (div.textContent || div.innerText || "").trim();
  }

  function animateCount(el: HTMLElement, target: number, duration = 1500) {
    const start = 0;
    const startTime = performance.now();
    function update(currentTime: number) {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const t = 1 - Math.pow(1 - progress, 3);
      const current = Math.floor(start + (target - start) * t);
      el.textContent = formatCount(current);
      if (progress < 1) requestAnimationFrame(update);
    }
    requestAnimationFrame(update);
  }

  /** 블로그 포스트 ID → 해당 영상 유튜브 링크 */
  const BLOG_TO_YOUTUBE: Record<string, string> = {
    "223554336299": "https://youtu.be/GBRSgYPD_v8?si=4Rhhrm2Eu9ojgDDD",
    "223630921092": "https://youtu.be/4W-6_M39Jr4?si=z5G76lXho02zYvPc",
    "223918535079": "https://youtu.be/Q9_ootsvDgQ?si=OIgX9Bao6dx3pZG5",
    "223723467910": "https://youtu.be/daabLwDGO7g?si=zDZE6rch9fiDDc0G",
    "223715629379": "https://youtu.be/oQXueYPPoSg?si=iwYOidkc31MQV99Q",
    "223594532420": "https://youtu.be/FsObBG1YIEA?si=PU24l0WbCn9RZaF9",
  };
  const YOUTUBE_CHANNEL_FALLBACK = "https://www.youtube.com/@holaphotograph";

  /** 블로그 카드에 필요한 최소 필드 (RSS 아이템 또는 정적 데이터 공통) */
  type BlogCardItem = {
    title: string;
    link: string;
    description?: string;
    thumbnail_url?: string | null;
    thumbnail_proxy_url?: string | null;
    youtube_url?: string;
  };

  function renderRssCard(
    item: BlogCardItem,
    options?: { priority?: "high" | "low" },
  ) {
    const imgUrl = getRssThumbnailUrl(item);
    const fetchPriority =
      options?.priority === "high" ? ' fetchpriority="high"' : "";
    const thumb = imgUrl
      ? `<div class="aspect-[209/314] w-full overflow-hidden bg-gray-200"><img src="${escapeHtml(imgUrl)}" alt="${escapeHtml(item.title)}" class="h-full w-full object-cover object-center opacity-0 transition-opacity duration-300" loading="lazy"${fetchPriority} decoding="async" onload="this.classList.add('opacity-100')" onerror="this.style.display='none'" /></div>`
      : '<div class="aspect-[209/314] w-full bg-gray-200" />';
    const rawDesc = item.description ?? "";
    const desc =
      stripHtml(rawDesc).slice(0, 80) +
      (stripHtml(rawDesc).length > 80 ? "..." : "");
    const blogPostId = item.link?.split("/").pop()?.trim() || "";
    const youtubeUrl =
      item.youtube_url ??
      BLOG_TO_YOUTUBE[blogPostId] ??
      YOUTUBE_CHANNEL_FALLBACK;
    return `
      <div class="blog-card scroll-row-item shrink-0 w-[209px] rounded-lg overflow-hidden bg-white shadow-md transition-all duration-300 hover:-translate-y-1 hover:scale-[1.02] hover:shadow-xl active:scale-[0.98]">
        <a href="${escapeHtml(item.link)}" target="_blank" rel="noopener" class="block">
          ${thumb}
          <div class="p-4 bg-white">
            <h3 class="font-semibold line-clamp-2 leading-relaxed text-sm text-[#111827]">${escapeHtml(item.title)}</h3>
            <p class="mt-1 line-clamp-2 text-xs text-[#6B7280]">${escapeHtml(desc)}</p>
          </div>
        </a>
        <div class="flex items-center justify-between gap-2 px-4 pb-4 pt-0">
          <a href="${escapeHtml(item.link)}" target="_blank" rel="noopener" class="text-xs text-[#E11D48] font-medium hover:underline">블로그 보기 →</a>
          <a href="${escapeHtml(youtubeUrl)}" target="_blank" rel="noopener" class="text-xs text-[#E11D48] font-medium hover:underline">유튜브 보기 →</a>
        </div>
      </div>
    `;
  }

  function renderYoutubeCard(
    v: YoutubeVideoItem,
    options?: { priority?: "high" | "low"; label?: string; isShort?: boolean },
  ) {
    const fetchPriority =
      options?.priority === "high" ? ' fetchpriority="high"' : "";
    const label = options?.label ?? "유튜브 보기 →";
    const cardWidth = options?.isShort ? "w-[209px]" : "w-[280px] sm:w-[340px]";
    const viewStr = v.viewCount ? formatCount(v.viewCount) + " 회" : "";
    const heartSvg = `<svg class="w-3.5 h-3.5 shrink-0 inline-block" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`;
    const commentSvg = `<svg class="w-3.5 h-3.5 shrink-0 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`;
    const likePart = v.likeCount ? `<span class="inline-flex items-center gap-0.5">${heartSvg}<span>${escapeHtml(formatCount(v.likeCount))}</span></span>` : "";
    const commentPart = v.commentCount ? `<span class="inline-flex items-center gap-0.5">${commentSvg}<span>${escapeHtml(formatCount(v.commentCount))}</span></span>` : "";
    const rightParts = [likePart, commentPart].filter(Boolean);
    const rightHtml = rightParts.join('<span class="text-gray-400 mx-0.5">·</span>');
    const leftHtml = viewStr ? escapeHtml(viewStr) : "";
    const hasMeta = leftHtml || rightHtml;
    let thumb: string;
    if (options?.isShort) {
      const aspect = "aspect-[209/314]";
      thumb = v.thumbnail_url
        ? `<div class="${aspect} w-full overflow-hidden bg-gray-200"><img src="${escapeHtml(v.thumbnail_url)}" alt="${escapeHtml(v.title)}" class="h-full w-full object-cover object-center opacity-0 transition-all duration-300 group-hover:scale-105" loading="lazy"${fetchPriority} decoding="async" onload="this.classList.add('opacity-100')" /></div>`
        : `<div class="${aspect} w-full bg-gray-200" />`;
    } else {
      const aspect = "aspect-video";
      thumb = v.thumbnail_url
        ? `<div class="${aspect} w-full overflow-hidden bg-gray-200"><img src="${escapeHtml(v.thumbnail_url)}" alt="${escapeHtml(v.title)}" class="h-full w-full object-cover opacity-0 transition-all duration-300 group-hover:scale-105" loading="lazy"${fetchPriority} decoding="async" onload="this.classList.add('opacity-100')" /></div>`
        : `<div class="${aspect} bg-gray-200" />`;
    }
    return `
      <a href="${escapeHtml(v.link)}" target="_blank" rel="noopener" class="yt-card group scroll-row-item shrink-0 ${cardWidth} rounded-lg overflow-hidden bg-white shadow-md transition-all duration-300 hover:-translate-y-1 hover:scale-[1.02] hover:shadow-xl active:scale-[0.98]">
        ${thumb}
        ${hasMeta ? `<div class="px-4 py-2 bg-gray-50 border-b border-gray-100 flex items-center justify-between gap-2 text-xs text-[#6B7280]"><span>${leftHtml}</span><span class="flex items-center shrink-0">${rightHtml}</span></div>` : ""}
        <div class="p-4 bg-white">
          <h3 class="font-semibold line-clamp-2 leading-relaxed text-sm sm:text-base text-[#111827]">${escapeHtml(v.title)}</h3>
          <p class="mt-1 text-xs text-[#E11D48] font-medium">${escapeHtml(label)}</p>
        </div>
      </a>
    `;
  }

  function renderRssSection(
    grid: HTMLElement,
    items: BlogCardItem[],
    emptyMsg: string,
    priority: "high" | "low" = "low",
  ) {
    if (items.length === 0) {
      grid.innerHTML = `<p class="shrink-0 px-4 sm:px-6 text-[#6B7280]">${emptyMsg}</p>`;
    } else {
      const toShow = items.slice(0, LIMIT);
      grid.innerHTML = toShow
        .map((item, i) =>
          renderRssCard(item, {
            priority: priority === "high" && i < 3 ? "high" : "low",
          }),
        )
        .join("");
    }
  }

  function renderYoutubeSection(
    grid: HTMLElement,
    items: YoutubeVideoItem[],
    emptyMsg: string,
    label: string,
    isShort = false,
  ) {
    if (items.length === 0) {
      grid.innerHTML = `<p class="shrink-0 px-4 sm:px-6 text-[#6B7280]">${emptyMsg}</p>`;
    } else {
      const toShow = items.slice(0, LIMIT);
      grid.innerHTML = toShow
        .map((v, i) =>
          renderYoutubeCard(v, {
            priority: i < 3 ? "high" : "low",
            label,
            isShort,
          }),
        )
        .join("");
    }
  }

  async function load() {
    try {
      const [youtubeRes, statsRes] = await Promise.all([
        fetchYoutubeLatest().catch(() => ({ videos: [], shorts: [], error: "Failed to load" })),
        fetchChannelStats().catch(() => null),
      ]);

      if (statsRes) {
        const subEl = document.getElementById("stats-youtube-subscribers");
        const viewsEl = document.getElementById("stats-youtube-views");
        const naverEl = document.getElementById("stats-naver-visitors");

        const subs = parseInt(statsRes.youtubeSubscribers ?? "0", 10);
        const views = parseInt(statsRes.youtubeViewCount ?? "0", 10);
        const naver = parseInt(statsRes.naverBlogVisitors ?? "0", 10);

        if (subEl && !isNaN(subs)) animateCount(subEl, subs);
        if (viewsEl && !isNaN(views)) viewsEl.textContent = formatCount(views);
        if (naverEl && !isNaN(naver)) animateCount(naverEl, naver);
      }

      const videos = youtubeRes.videos || [];
      const videosSorted = sortByPreferredOrder(videos, YOUTUBE_LONG_ORDER);
      const shorts = youtubeRes.shorts || [];

      renderYoutubeSection(
        youtubeLongGrid,
        videosSorted,
        "데이터 준비 중입니다.",
        "유튜브 보기 →",
      );
      setTimeout(() => {
        renderYoutubeSection(
          youtubeShortsGrid,
          shorts,
          "데이터 준비 중입니다.",
          "Shorts 보기 →",
          true,
        );
      }, 80);

      // 블로그 섹션: RSS 대신 정적 데이터 사용
      setTimeout(() => {
        renderRssSection(
          blogGrid,
          FEATURED_BLOG,
          "장비 비교·상세 분석 콘텐츠가 없습니다.",
          "high",
        );
      }, 160);
    } catch (e) {
      youtubeLongGrid.innerHTML = `<p class="shrink-0 px-4 sm:px-6 text-[#E11D48]">영상을 불러올 수 없습니다</p>`;
      youtubeShortsGrid.innerHTML =
        '<p class="shrink-0 px-4 sm:px-6 text-[#E11D48]">Shorts를 불러올 수 없습니다</p>';
      blogGrid.innerHTML =
        '<p class="shrink-0 px-4 sm:px-6 text-[#E11D48]">블로그를 불러올 수 없습니다</p>';
    }
  }

  load();

  // 강의 홍보 팝업: 메인 진입 시 1회 (오늘 하루 안 보기 가능)
  (function initClassPromoPopup() {
    const STORAGE_KEY = 'holaphoto-class-popup-seen';
    const popup = document.getElementById('class-promo-popup');
    const closeBtn = document.getElementById('class-promo-close');
    const closeBtn2 = document.getElementById('class-promo-close-btn');
    const dontShow = document.getElementById('class-promo-dont-show') as HTMLInputElement | null;

    function hidePopup() {
      popup?.classList.add('hidden');
      popup?.classList.remove('flex');
    }

    function showPopup() {
      popup?.classList.remove('hidden');
      popup?.classList.add('flex');
    }

    function shouldShowPopup(): boolean {
      try {
        const raw = sessionStorage.getItem(STORAGE_KEY);
        if (!raw) return true;
        const data = JSON.parse(raw) as { date?: string };
        if (!data.date) return true;
        const today = new Date().toDateString();
        return data.date !== today;
      } catch {
        return true;
      }
    }

    function setDontShowToday() {
      try {
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify({ date: new Date().toDateString() }));
      } catch (_) {}
    }

    if (shouldShowPopup()) {
      showPopup();
    }

    function close() {
      if (dontShow?.checked) setDontShowToday();
      hidePopup();
    }

    closeBtn?.addEventListener('click', close);
    closeBtn2?.addEventListener('click', close);
    popup?.addEventListener('click', (e) => {
      if (e.target === popup) close();
      const link = (e.target as Element).closest('.class-promo-image-link');
      if (link) hidePopup(); // 이미지 클릭 시 팝업만 닫고, 링크 기본 동작(/notice?id=2 상세 이동)은 그대로
    });
  })();

  // 강의 팝업 내부 슬라이드 (트랙 width 200%, 슬라이드당 50% 이동)
  (function initClassPromoSlider() {
    const track = document.querySelector('.class-promo-track') as HTMLElement | null;
    const total = 2;
    let current = 0;
    const AUTOPLAY_MS = 3000;

    function goTo(i: number) {
      current = ((i % total) + total) % total;
      if (track) track.style.transform = `translateX(-${current * 50}%)`;
    }

    const slider = document.getElementById('class-promo-slider');
    let touchStartX = 0;
    slider?.addEventListener('touchstart', (e) => { touchStartX = (e as TouchEvent).touches[0].clientX; }, { passive: true });
    slider?.addEventListener('touchend', (e) => {
      const dx = (e as TouchEvent).changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) dx < 0 ? goTo(current + 1) : goTo(current - 1);
    }, { passive: true });

    setInterval(() => goTo(current + 1), AUTOPLAY_MS);
  })();
</script>

<style is:global>
  .hero-slide-2-inner { overflow: visible; }
  .hero-slide-2-desc { overflow-wrap: break-word; word-break: keep-all; }
  /* 모바일: 히어로 2번 슬라이드 내 이미지 1장, 정중앙·보더는 이미지 크기에 맞춤 */
  .hero-slide-2-mobile-images {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0.25rem 0 0.5rem;
  }
  .hero-slide-2-mobile-single { display: inline-flex; line-height: 0; max-width: 100%; }
  .hero-slide-2-mobile-single img { max-width: 100%; }
  /* 모바일 전용: 768px 이상에서는 모바일 이미지 영역 숨김 (PC에서 중복 방지) */
  @media (min-width: 768px) {
    .hero-slide-2-mobile-images { display: none !important; }
    .hero-class-slide { width: auto; min-width: 0; }
  }
  /* 데스크톱용 2장 영역은 모바일에서만 숨김 */
